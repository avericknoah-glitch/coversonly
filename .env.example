# ─── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database (PostgreSQL) ────────────────────────────────
# Option A: full connection string (recommended for Supabase)
DATABASE_URL=postgresql://user:password@host:5432/lineup_db

# Option B: individual fields (for local Postgres)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=lineup_db
# DB_USER=postgres
# DB_PASSWORD=yourpassword

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string_here
JWT_EXPIRES_IN=7d

# ─── The Odds API ─────────────────────────────────────────
# Sign up free at https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# How often to refresh odds from the API (minutes)
# Free tier: 500 req/month — every 30 min on 3 sports ≈ 144 req/day
# Set higher to conserve credits while developing
ODDS_REFRESH_INTERVAL_MINUTES=30

# Comma-separated bookmakers to pull lines from
# Options: draftkings, fanduel, betmgm, caesars, bovada, mybookieag
ODDS_BOOKMAKERS=draftkings,fanduel,betmgm

# ─── CORS ─────────────────────────────────────────────────
# Your frontend URL(s), comma separated
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
